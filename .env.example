# Database Configurations (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres_password@db:5432/expense_tracker?schema=public"
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_password
POSTGRES_DB=expense_tracker

# JWT Authentication Secret
JWT_SECRET="replace_with_a_secure_jwt_secret_string"

# Backend Server Configuration
PORT=5000
NODE_ENV=production

# Frontend Environment Configuration
NEXT_PUBLIC_API_URL="http://localhost:5000/api"

# Telegram Bot Configurations
TELEGRAM_BOT_TOKEN="your_telegram_bot_token_from_botfather"
TELEGRAM_BOT_SECRET="choose_a_custom_shared_password_for_bot_api"
BACKEND_API_URL="http://backend:5000/api"

# Gemini AI API Key
GEMINI_API_KEY="your_google_gemini_api_key"

# Google Sheets Integration Setup
GOOGLE_SHEETS_SPREADSHEET_ID="your_google_spreadsheet_id"
# Google Service Account JSON credentials must be pasted below as a single line string
GOOGLE_SERVICE_ACCOUNT_CREDENTIALS='{"type": "service_account", "project_id": "...", "private_key_id": "...", "private_key": "...", "client_email": "...", "client_id": "..."}'
